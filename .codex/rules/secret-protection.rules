# Codex rules: secret protection
# Blocks commands that read or expose secrets, tokens, keys, or credentials.

# --- Block env/printenv dumps ---
prefix_rule(
    pattern = ["env"],
    decision = "forbidden",
    justification = "Bare env dumps all environment variables. Set vars in the shell or use source .env.",
    match = ["env"],
    not_match = ["env HOME=/tmp", "env FOO=bar", "env PATH=/bin true"],
)

prefix_rule(
    pattern = ["printenv"],
    decision = "forbidden",
    justification = "printenv would dump all environment variables.",
    match = ["printenv"],
    not_match = ["printenv HOME", "printenv USER"],
)

# --- Block echo/printf of env vars ---
prefix_rule(
    pattern = ["bash", "-c"],
    decision = "prompt",
    justification = "bash -c may read secrets. Verify the command does not expose credentials.",
)

# --- Block shell spawns that bypass guard ---
prefix_rule(
    pattern = ["bash"],
    decision = "forbidden",
    justification = "Bare bash spawns an unguarded shell. Use bash script.sh with a named script file.",
    match = ["bash", "bash -l"],
)

prefix_rule(
    pattern = ["zsh"],
    decision = "forbidden",
    justification = "Bare zsh spawns an unguarded shell.",
    match = ["zsh", "zsh -l"],
)

prefix_rule(
    pattern = ["sh"],
    decision = "forbidden",
    justification = "Bare sh spawns an unguarded shell.",
    match = ["sh", "sh -l"],
)

# --- Block gh auth token ---
prefix_rule(
    pattern = ["gh", "auth", "token"],
    decision = "forbidden",
    justification = "gh auth token prints your GitHub token to stdout. Use gh auth status instead.",
    match = ["gh auth token"],
)

# --- Block declare/typeset -p and bare set ---
prefix_rule(
    pattern = ["declare", "-p"],
    decision = "forbidden",
    justification = "declare -p prints variable values. Use guard_check VARNAME instead.",
    match = ["declare -p HOME", "declare -p TOKEN"],
)

prefix_rule(
    pattern = ["typeset", "-p"],
    decision = "forbidden",
    justification = "typeset -p prints variable values.",
    match = ["typeset -p HOME"],
)
